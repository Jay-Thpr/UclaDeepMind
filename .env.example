# Backend (copy to backend/.env or set when running uvicorn)
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Google OAuth — create an OAuth 2.0 Client (Web application) in Google Cloud Console
# Enable Google Photos Library API if you want annotated stills uploaded to per-skill albums.
# Authorized redirect URI must match exactly (dev: Vite app + /auth/callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
# Optional: service-account JSON (single-line JSON string) for best-effort Docs summary exports.
GOOGLE_DOCS_SERVICE_ACCOUNT_JSON=
# Optional shared Drive / folder id where exported summary docs should be created.
GOOGLE_DOCS_EXPORT_FOLDER_ID=

# Session JWT (HS256) — use a long random string in production
JWT_SECRET=
# Set true behind HTTPS in production
COOKIE_SECURE=false

# SQLite by default: backend/data/app.db — override with full URL if needed
# DATABASE_URL=sqlite:////absolute/path/app.db

# Gemini — required for Live coach (ephemeral tokens; keep secret)
GEMINI_API_KEY=
# Live model id (no "models/" prefix); must support Live API for your key
# Use a Live-capable id from https://ai.google.dev/gemini-api/docs/models
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Still-frame form annotations (image + text); same key as GEMINI_API_KEY
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Skill research dossier (REST generateContent + thinking when supported). Override with an id from scripts/check_gemini_key.py
GEMINI_RESEARCH_MODEL=gemini-3-flash-preview

# Nano Banana / image generation (later)
NANO_BANANA_API_KEY=
NANO_BANANA_BASE_URL=

# Background removal: rembg (local, default) or remove_bg (cloud API)
BACKGROUND_REMOVAL_PROVIDER=rembg
# rembg: sharper sprite edges (0 = soft alpha; 200 recommended for pixel art)
REMBG_POST_PROCESS_MASK=true
REMBG_ALPHA_THRESHOLD=200
# Only if BACKGROUND_REMOVAL_PROVIDER=remove_bg — https://www.remove.bg/api
REMOVE_BG_API_KEY=

# Frontend (optional — empty uses Vite proxy to FastAPI)
# VITE_API_URL=http://localhost:8000
